# ============================================
# 短链接系统 - 环境变量配置模板
# 使用说明：复制此文件为 .env，根据实际情况修改值
# ============================================

# 服务监听端口
PORT=3000

# 运行环境: development / production
NODE_ENV=development

# 域名配置（用于生成短链接URL，不带末尾斜杠）
# 示例: http://localhost:3000  或  https://your-domain.com
BASE_URL=http://localhost:3000

# JWT 密钥（请务必修改为随机高强度字符串，生产环境禁止使用默认值！）
# 可用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please_change_this_to_a_strong_random_string_in_production

# JWT Token 有效期（默认7天）
JWT_EXPIRES_IN=7d
